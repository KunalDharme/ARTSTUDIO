# Copy this to .env for local development (never commit .env to git)

# JWT Secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FASTAPI_SECRET_KEY=your-secret-key-here

# Resend email (get free key at resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=ArtStudio <noreply@yourdomain.com>

# App URL (used in emails)
APP_URL=https://your-app.railway.app

# Cloudinary (get from cloudinary.com dashboard)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# PostgreSQL (Railway sets this automatically as DATABASE_URL)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
